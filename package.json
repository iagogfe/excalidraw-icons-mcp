{
  "name": "excalidraw-icons-mcp",
  "version": "1.0.7",
  "description": "Faster Excalidraw MCP server with real icon/library search and insertion for agent-built diagrams",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "excalidraw-icons-mcp": "dist/index.js"
  },
  "scripts": {
    "start": "npm run build:server && node dist/index.js",
    "canvas": "npm run build:server && node dist/server.js",
    "build": "npm run build:frontend && npm run build:server",
    "build:frontend": "vite build",
    "build:server": "npx tsc",
    "dev": "concurrently \"npm run dev:server\" \"vite\"",
    "dev:server": "npx tsc --watch",
    "production": "npm run build && npm run canvas",
    "prepublishOnly": "npm run build",
    "test:bind": "npm run build:server && node scripts/check-local-bind.mjs",
    "test:libraries": "npm run build:server && node scripts/test-libraries.mjs",
    "test:conventions": "npm run build:server && node scripts/test-conventions.mjs",
    "type-check": "npx tsc --noEmit"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@excalidraw/mermaid-to-excalidraw": "^1.1.3",
    "@modelcontextprotocol/sdk": "latest",
    "@tabler/icons": "^3.44.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-icons": "^16.24.1",
    "ws": "^8.14.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.7",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "excalidraw",
    "model-context-protocol",
    "ai",
    "drawing",
    "diagrams",
    "canvas",
    "real-time",
    "websocket",
    "visualization",
    "claude",
    "ai-tools"
  ],
  "author": {
    "name": "Iago Gonçalves",
    "url": "https://github.com/iagogfe"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iagogfe/excalidraw-icons-mcp.git"
  },
  "homepage": "https://github.com/iagogfe/excalidraw-icons-mcp#readme",
  "bugs": {
    "url": "https://github.com/iagogfe/excalidraw-icons-mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "src/**/*",
    "dist/**/*",
    "icons/**/*",
    "*.d.ts",
    "README.md",
    "LICENSE"
  ]
}
